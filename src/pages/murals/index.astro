---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import SectionHead from '~/components/SectionHead.astro';
import MuralCase from '~/components/MuralCase.astro';
import RevealScript from '~/components/RevealScript.astro';

const murals = (await getCollection('murals')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  tone="teal"
  title="Murals"
  description="Public and community mural work by Xee Reiter across Saint Paul and the Twin Cities."
>
  <section class="pb-20 pt-14 md:pb-24 md:pt-16">
    <div class="mx-auto max-w-6xl px-5 sm:px-8">
      <SectionHead as="h1" eyebrow="Public work" title="Murals & place-based projects" />
      <div class="divide-y divide-line">
        {murals.map((mural, i) => <MuralCase mural={mural} reverse={i % 2 === 1} priority={i === 0} />)}
      </div>
    </div>
  </section>
  <RevealScript />
</BaseLayout>
