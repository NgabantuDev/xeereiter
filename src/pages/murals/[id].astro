---
import { getCollection, render } from 'astro:content';
import { getImage } from 'astro:assets';
import BaseLayout from '~/layouts/BaseLayout.astro';
import ArtTile from '~/components/ArtTile.astro';
import RevealScript from '~/components/RevealScript.astro';

export async function getStaticPaths() {
  const murals = await getCollection('murals');
  return murals.map((mural) => ({ params: { id: mural.id }, props: { mural } }));
}

const { mural } = Astro.props;
const { title, location, partner, year, description, image, alt, swatch } = mural.data;
const { Content } = await render(mural);
const ogImage = image
  ? (await getImage({ src: image, width: Math.min(1200, image.width), format: 'jpg' })).src
  : undefined;
---

<BaseLayout tone="teal" title={title} description={description} image={ogImage}>
  <section class="pb-20 pt-14 md:pb-24 md:pt-16">
    <div class="mx-auto max-w-5xl px-5 sm:px-8">
      <a href="/murals" class="text-sm font-semibold text-ink-soft no-underline hover:text-ink">← All murals</a>
      <div class="mt-8 grid gap-12 md:grid-cols-[1.1fr_0.9fr] md:items-start">
        <ArtTile {image} alt={alt ?? title} {swatch} aspect="auto" sizes="(min-width: 900px) 55vw, 100vw" priority />
        <div>
          <span class="inline-flex items-center gap-1.5 font-mono text-[11px] uppercase tracking-wide text-teal-text">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 21s7-7.2 7-12a7 7 0 1 0-14 0c0 4.8 7 12 7 12Z"></path>
              <circle cx="12" cy="9" r="2.4"></circle>
            </svg>
            {location}
          </span>
          <h1 class="mt-2 text-4xl font-extrabold">{title}</h1>
          <dl class="mt-6 space-y-3 border-t border-line pt-6 text-sm">
            {
              partner && (
                <div class="flex justify-between gap-4">
                  <dt class="text-ink-soft">Partner</dt>
                  <dd class="text-right font-semibold">{partner}</dd>
                </div>
              )
            }
            {
              year && (
                <div class="flex justify-between gap-4">
                  <dt class="text-ink-soft">Year</dt>
                  <dd class="text-right font-semibold">{year}</dd>
                </div>
              )
            }
          </dl>
          <div class="mt-6 max-w-[52ch] text-[15px] text-ink-soft">
            <p>{description}</p>
            <Content />
          </div>
        </div>
      </div>
    </div>
  </section>
  <RevealScript />
</BaseLayout>
