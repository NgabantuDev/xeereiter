---
import BaseLayout from '~/layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" description="This page doesn't exist.">
  <section class="py-28 text-center">
    <div class="mx-auto max-w-lg px-5 sm:px-8">
      <span class="sec-num">404</span>
      <h1 class="mt-3 text-3xl font-extrabold">This page wandered off the page.</h1>
      <p class="mt-4 text-ink-soft">The link might be old, or the page might have moved.</p>
      <a href="/" class="btn-primary mt-8 inline-flex">Back to home</a>
    </div>
  </section>
</BaseLayout>
