---
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import ScrollSpine from '~/components/ScrollSpine.astro';
import '~/styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
}

const { title, description, image = '/og-image.jpg' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <title>{title} · Xee Reiter</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Xee Reiter" />
    <meta property="og:title" content={`${title} · Xee Reiter`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: 'Xee Reiter',
        jobTitle: 'Illustrator & Muralist',
        url: 'https://www.xeereiter.com',
        address: { '@type': 'PostalAddress', addressLocality: 'Saint Paul', addressRegion: 'MN' },
        sameAs: ['https://www.instagram.com/xeereiter/'],
      })}
    />
  </head>
  <body class="font-sans text-ink antialiased">
    <a
      href="#main"
      class="sr-only rounded-md bg-ink px-4 py-2 font-semibold text-paper focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100]"
    >
      Skip to main content
    </a>
    <ScrollSpine />
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
