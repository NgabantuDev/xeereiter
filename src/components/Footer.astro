---
const year = new Date().getFullYear();
---

<footer class="border-t border-line">
  <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-5 py-9 text-[13px] text-ink-soft sm:px-8">
    <span>© {year} Xee Reiter — Illustrator &amp; Muralist</span>
    <div class="flex gap-2.5">
      <a
        href="https://www.instagram.com/xeereiter/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram"
        class="inline-flex h-8.5 w-8.5 items-center justify-center rounded-full border border-line text-ink no-underline hover:border-ink"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <rect x="3" y="3" width="18" height="18" rx="5"></rect>
          <circle cx="12" cy="12" r="4"></circle>
        </svg>
      </a>
      <a
        href="mailto:hello@xeereiter.com"
        aria-label="Email"
        class="inline-flex h-8.5 w-8.5 items-center justify-center rounded-full border border-line text-ink no-underline hover:border-ink"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <rect x="3" y="5" width="18" height="14" rx="2"></rect>
          <path d="m4 6 8 6 8-6"></path>
        </svg>
      </a>
    </div>
  </div>
</footer>
