---
interface Props {
  compact?: boolean;
  as?: 'h1' | 'h2';
}
const { compact = false, as: Tag = 'h2' } = Astro.props;
---

<div class="reveal text-center">
  <span class="font-mono text-xs uppercase tracking-wide text-ink-soft">Get in touch</span>
  <Tag class:list={['mx-auto mt-3.5 max-w-[16ch] font-extrabold', compact ? 'text-[clamp(26px,4vw,38px)]' : 'text-[clamp(30px,5vw,52px)]']}>
    Have a wall, a bottle label, or a story to tell?
  </Tag>
  <p class="mt-4 text-ink-soft">Based in Saint Paul, taking mural and illustration commissions.</p>
  <div class="mt-8 flex flex-wrap justify-center gap-3.5">
    <a href="mailto:hello@xeereiter.com" class="btn-primary"> hello@xeereiter.com </a>
    <a href="/illustrations" class="btn-ghost"> View the work </a>
  </div>
</div>
