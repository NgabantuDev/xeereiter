---
import Wordmark from './Wordmark.astro';

const nav = [
  { href: '/about', label: 'About' },
  { href: '/illustrations', label: 'Illustration' },
  { href: '/murals', label: 'Murals' },
  { href: '/press', label: 'Press' },
  { href: '/contact', label: 'Contact' },
];

const path = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-line bg-paper/90 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5 sm:px-8">
    <a href="/" class="flex items-baseline gap-2 whitespace-nowrap text-xl no-underline">
      <Wordmark />
      <span class="hidden font-mono text-[10px] font-semibold uppercase tracking-wider text-ink-soft sm:inline">
        Illustrator &amp; Muralist
      </span>
    </a>

    <nav aria-label="Primary" class="hidden items-center gap-7 md:flex">
      {
        nav.map((item) => (
          <a
            href={item.href}
            aria-current={path.startsWith(item.href) ? 'page' : undefined}
            class="group relative py-1 text-sm font-semibold text-ink-soft no-underline aria-[current]:text-ink hover:text-ink"
          >
            {item.label}
            <span class="absolute inset-x-0 -bottom-0.5 h-0.5 origin-left scale-x-0 bg-pink transition-transform duration-200 group-hover:scale-x-100 group-aria-[current]:scale-x-100" />
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        href="https://www.instagram.com/xeereiter/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Xeereiter on Instagram"
        class="inline-flex h-8.5 w-8.5 items-center justify-center rounded-full border border-line text-ink no-underline hover:border-ink"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <rect x="3" y="3" width="18" height="18" rx="5"></rect>
          <circle cx="12" cy="12" r="4"></circle>
          <circle cx="17.2" cy="6.8" r="1"></circle>
        </svg>
      </a>
      <button
        id="menu-btn"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
        class="inline-flex h-9.5 w-9.5 items-center justify-center rounded-lg border border-line text-ink md:hidden"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 6h18M3 12h18M3 18h18"></path>
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-nav" aria-label="Mobile" class="hidden flex-col border-t border-line bg-paper md:hidden">
    {
      nav.map((item) => (
        <a href={item.href} class="border-t border-line px-5 py-3.5 text-[15px] font-semibold text-ink no-underline first:border-t-0">
          {item.label}
        </a>
      ))
    }
  </nav>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const panel = document.getElementById('mobile-nav');
  btn?.addEventListener('click', () => {
    const open = panel?.classList.toggle('flex');
    panel?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', open ? 'true' : 'false');
  });
  panel?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      panel.classList.add('hidden');
      panel.classList.remove('flex');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
